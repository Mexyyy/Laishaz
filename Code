<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
  // ── DATA STORE ──
  let appointments = JSON.parse(localStorage.getItem('laishaz_appts') || '[]');
  let customers = JSON.parse(localStorage.getItem('laishaz_customers') || '[]');
  let currentCustomer = JSON.parse(localStorage.getItem('laishaz_current_customer') || 'null');
  let booking = { service: '', date: '', time: '', name: '', phone: '', email: '', notes: '' };
  let currentStep = 1;
  let adminLoggedIn = false;
  let currentFilter = 'all';

  // ── PAGE NAVIGATION ──
  function showPage(id, linkEl) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
    document.getElementById('page-' + id).classList.add('active');
    if (linkEl) linkEl.classList.add('active');
    window.scrollTo(0, 0);

    if (id === 'admin') {
      if (adminLoggedIn) showDash();
      else showLoginPanel();
    }
    if (id === 'account') {
      renderAccountPage();
    }
  }

  // ── NAV ACCOUNT BUTTON ──
  function handleNavAccountClick(linkEl) {
    if (currentCustomer) {
      showPage('account', linkEl);
    } else {
      showPage('login', linkEl);
      switchLoginTab('customer');
    }
  }

  function refreshNavLoginLink() {
    const link = document.getElementById('nav-login-link');
    if (currentCustomer) {
      link.textContent = 'My Account';
    } else {
      link.textContent = 'Login';
    }
  }

  // ── LOGIN PAGE TABS ──
  function switchLoginTab(which) {
    document.getElementById('login-tab-customer').classList.toggle('active', which === 'customer');
    document.getElementById('login-tab-admin').classList.toggle('active', which === 'admin');
    document.getElementById('login-customer-panel').style.display = which === 'customer' ? '' : 'none';
    document.getElementById('login-admin-panel').style.display = which === 'admin' ? '' : 'none';
  }

  function toggleCustMode(mode) {
    document.getElementById('cust-mode-login').style.display = mode === 'login' ? '' : 'none';
    document.getElementById('cust-mode-signup').style.display = mode === 'signup' ? '' : 'none';
    document.getElementById('custLoginErr').style.display = 'none';
    document.getElementById('custSignErr').style.display = 'none';
  }

  // ── CUSTOMER AUTH ──
  function saveCustomers() { localStorage.setItem('laishaz_customers', JSON.stringify(customers)); }
  function saveCurrentCustomer() {
    localStorage.setItem('laishaz_current_customer', JSON.stringify(currentCustomer));
  }

  function customerSignup() {
    const name = document.getElementById('custSignName').value.trim();
    const phone = document.getElementById('custSignPhone').value.trim();
    const email = document.getElementById('custSignEmail').value.trim();
    const pass = document.getElementById('custSignPass').value;
    const errEl = document.getElementById('custSignErr');

    if (!name || !phone || !pass) {
      errEl.textContent = '⚠ Please fill in name, phone, and password.';
      errEl.style.display = 'block';
      return;
    }
    if (pass.length < 6) {
      errEl.textContent = '⚠ Password must be at least 6 characters.';
      errEl.style.display = 'block';
      return;
    }
    const exists = customers.find(c => c.phone === phone || (email && c.email === email));
    if (exists) {
      errEl.textContent = '⚠ An account with this phone or email already exists.';
      errEl.style.display = 'block';
      return;
    }
    const newCust = { id: Date.now(), name, phone, email, password: pass };
    customers.push(newCust);
    saveCustomers();
    currentCustomer = newCust;
    saveCurrentCustomer();
    refreshNavLoginLink();
    showToast('✅ Account created! Welcome, ' + name + '.');
    document.getElementById('custSignName').value = '';
    document.getElementById('custSignPhone').value = '';
    document.getElementById('custSignEmail').value = '';
    document.getElementById('custSignPass').value = '';
    errEl.style.display = 'none';
    showPage('account', null);
  }

  function customerLogin() {
    const id = document.getElementById('custLoginId').value.trim();
    const pass = document.getElementById('custLoginPass').value;
    const errEl = document.getElementById('custLoginErr');

    const cust = customers.find(c =>
      (c.phone === id || c.email === id) && c.password === pass
    );
    if (!cust) {
      errEl.textContent = '⚠ Invalid login. Please check your details.';
      errEl.style.display = 'block';
      return;
    }
    currentCustomer = cust;
    saveCurrentCustomer();
    refreshNavLoginLink();
    document.getElementById('custLoginId').value = '';
    document.getElementById('custLoginPass').value = '';
    errEl.style.display = 'none';
    showToast('✅ Welcome back, ' + cust.name + '!');
    showPage('account', null);
  }

  function customerLogout() {
    currentCustomer = null;
    saveCurrentCustomer();
    refreshNavLoginLink();
    showToast('You have been logged out.');
    showPage('home', document.querySelector('.nav-links a'));
  }

  function getCustomerAppointments() {
    if (!currentCustomer) return [];
    return appointments.filter(a =>
      a.customerId === currentCustomer.id ||
      a.phone === currentCustomer.phone ||
      (currentCustomer.email && a.email === currentCustomer.email)
    );
  }

  function renderAccountPage() {
    if (!currentCustomer) {
      showPage('login', null);
      switchLoginTab('customer');
      return;
    }
    document.getElementById('account-greeting').textContent =
      'Hello, ' + currentCustomer.name + ' — here are your past and upcoming appointments.';

    const list = getCustomerAppointments();
    const today = new Date().toISOString().split('T')[0];
    const total = list.length;
    const upcoming = list.filter(a => a.date >= today && a.status !== 'done').length;
    const completed = list.filter(a => a.status === 'done').length;
    const pending = list.filter(a => a.status === 'pending').length;

    document.getElementById('cust-stat-total').textContent = total;
    document.getElementById('cust-stat-upcoming').textContent = upcoming;
    document.getElementById('cust-stat-completed').textContent = completed;
    document.getElementById('cust-stat-pending').textContent = pending;

    const tbody = document.getElementById('cust-appt-tbody');
    if (list.length === 0) {
      tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><div class="ei">📭</div><p>You don't have any appointments yet.</p></div></td></tr>`;
      return;
    }
    // Sort: most recent first
    const sorted = [...list].sort((a, b) => (b.date + b.time).localeCompare(a.date + a.time));
    tbody.innerHTML = sorted.map((a, i) => {
      const d = new Date(a.date);
      const dateStr = d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
      const badge = a.status === 'pending' ? 'badge-pending' : a.status === 'confirmed' ? 'badge-confirmed' : 'badge-done';
      const statusLabel = a.status.charAt(0).toUpperCase() + a.status.slice(1);
      return `
        <tr>
          <td>${i + 1}</td>
          <td><strong>${a.service}</strong></td>
          <td>${dateStr}</td>
          <td>${a.time}</td>
          <td><span class="badge ${badge}">${statusLabel}</span></td>
          <td style="font-size:0.83rem; color:var(--text-light);">${a.notes || '—'}</td>
        </tr>`;
    }).join('');
  }

  // ── SERVICE CATEGORIES ──
  function showCat(cat, btn) {
    document.querySelectorAll('.service-list').forEach(l => l.classList.remove('active'));
    document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('cat-' + cat).classList.add('active');
    btn.classList.add('active');
  }

  // ── BOOKING MODAL ──
  function openBooking() {
    document.getElementById('booking-modal').classList.add('open');
    currentStep = 1;
    booking = { service: '', date: '', time: '', name: '', phone: '', email: '', notes: '' };
    renderStep(1);
    // Set min date to today
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('appt-date').min = today;
    document.getElementById('appt-date').value = today;
    booking.date = today;
    // Prefill if customer is logged in
    if (currentCustomer) {
      document.getElementById('book-name').value = currentCustomer.name || '';
      document.getElementById('book-phone').value = currentCustomer.phone || '';
      document.getElementById('book-email').value = currentCustomer.email || '';
    } else {
      document.getElementById('book-name').value = '';
      document.getElementById('book-phone').value = '';
      document.getElementById('book-email').value = '';
    }
    document.getElementById('book-notes').value = '';
  }

  function closeBooking() {
    document.getElementById('booking-modal').classList.remove('open');
    // Reset selections
    document.querySelectorAll('.svc-option').forEach(o => o.classList.remove('selected'));
    document.querySelectorAll('.time-slot').forEach(t => t.classList.remove('selected'));
  }

  function renderStep(n) {
    for (let i = 1; i <= 5; i++) {
      document.getElementById('bs-' + i).classList.remove('active');
      if (i <= 4) {
        const tab = document.getElementById('step-tab-' + i);
        tab.classList.remove('active', 'done');
        if (i === n) tab.classList.add('active');
        else if (i < n) tab.classList.add('done');
      }
    }
    document.getElementById('bs-' + n).classList.add('active');
    currentStep = n;
  }

  function goStep(n) {
    if (n === 2 && !booking.service) { showToast('Please select a service first.'); return; }
    if (n === 3 && !booking.time) { showToast('Please select a time slot.'); return; }
    if (n === 4) {
      booking.name = document.getElementById('book-name').value.trim();
      booking.phone = document.getElementById('book-phone').value.trim();
      booking.email = document.getElementById('book-email').value.trim();
      booking.notes = document.getElementById('book-notes').value.trim();
      if (!booking.name) { showToast('Please enter your name.'); return; }
      if (!booking.phone) { showToast('Please enter your phone number.'); return; }
      booking.date = document.getElementById('appt-date').value;
      renderConfirmation();
    }
    renderStep(n);
  }

  function selectService(el, name) {
    document.querySelectorAll('.svc-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    booking.service = name;
  }

  function selectTime(el, time) {
    document.querySelectorAll('.time-slot:not(.unavailable)').forEach(t => t.classList.remove('selected'));
    el.classList.add('selected');
    booking.time = time;
  }

  function renderConfirmation() {
    const d = new Date(booking.date);
    const dateStr = d.toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    document.getElementById('conf-box').innerHTML = `
      <div class="conf-row"><span>Service</span><span>${booking.service}</span></div>
      <div class="conf-row"><span>Date</span><span>${dateStr}</span></div>
      <div class="conf-row"><span>Time</span><span>${booking.time}</span></div>
      <div class="conf-row"><span>Name</span><span>${booking.name}</span></div>
      <div class="conf-row"><span>Phone</span><span>${booking.phone}</span></div>
      ${booking.notes ? `<div class="conf-row"><span>Notes</span><span>${booking.notes}</span></div>` : ''}
    `;
  }

  function confirmBooking() {
    const appt = {
      id: Date.now(),
      customerId: currentCustomer ? currentCustomer.id : null,
      name: booking.name,
      phone: booking.phone,
      email: booking.email,
      service: booking.service,
      date: booking.date,
      time: booking.time,
      notes: booking.notes,
      status: 'pending'
    };
    appointments.unshift(appt);
    saveAppts();
    renderStep(5);
    // Reset booking steps tab display
    document.querySelectorAll('[id^="step-tab-"]').forEach(t => t.classList.remove('active', 'done'));
  }

  // ── ADMIN ──
  function showLoginPanel() {
    document.getElementById('admin-login').style.display = 'flex';
    document.getElementById('admin-dash').classList.remove('visible');
  }

  function showDash() {
    document.getElementById('admin-login').style.display = 'none';
    document.getElementById('admin-dash').classList.add('visible');
    renderDash();
  }

  const ADMIN_ACCOUNTS = [
    { username: 'admin', password: 'laishaz2025' },
    { username: 'gautam', password: 'gautam' }
  ];

  function adminLogin() {
    const u = document.getElementById('adminUser').value;
    const p = document.getElementById('adminPass').value;
    const match = ADMIN_ACCOUNTS.find(a => a.username === u && a.password === p);
    if (match) {
      adminLoggedIn = true;
      document.getElementById('loginErr').style.display = 'none';
      document.getElementById('nav-admin-li').style.display = '';
      showDash();
    } else {
      document.getElementById('loginErr').style.display = 'block';
    }
  }

  function adminLogout() {
    adminLoggedIn = false;
    document.getElementById('nav-admin-li').style.display = 'none';
    showLoginPanel();
    showPage('home', document.querySelector('.nav-links a'));
  }

  function renderDash() {
    updateStats();
    renderTable(currentFilter);
  }

  function updateStats() {
    const total = appointments.length;
    const pending = appointments.filter(a => a.status === 'pending').length;
    const confirmed = appointments.filter(a => a.status === 'confirmed').length;
    const done = appointments.filter(a => a.status === 'done').length;
    document.getElementById('stat-total').textContent = total;
    document.getElementById('stat-pending').textContent = pending;
    document.getElementById('stat-confirmed').textContent = confirmed;
    document.getElementById('stat-done').textContent = done;
  }

  function filterAppts(type, btn) {
    currentFilter = type;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderTable(type);
  }

  function renderTable(filter) {
    const tbody = document.getElementById('appt-tbody');
    let list = filter === 'all' ? appointments : appointments.filter(a => a.status === filter);

    if (list.length === 0) {
      tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><div class="ei">📭</div><p>No appointments found.</p></div></td></tr>`;
      return;
    }

    tbody.innerHTML = list.map((a, i) => {
      const d = new Date(a.date);
      const dateStr = d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
      const badge = a.status === 'pending' ? 'badge-pending' : a.status === 'confirmed' ? 'badge-confirmed' : 'badge-done';
      const statusLabel = a.status.charAt(0).toUpperCase() + a.status.slice(1);
      return `
        <tr>
          <td>${i + 1}</td>
          <td><strong>${a.name}</strong></td>
          <td>${a.phone}</td>
          <td>${a.service}</td>
          <td>${dateStr}</td>
          <td>${a.time}</td>
          <td><span class="badge ${badge}">${statusLabel}</span></td>
          <td>
            ${a.status === 'pending' ? `<button class="action-btn btn-confirm" onclick="updateStatus(${a.id}, 'confirmed')">Confirm</button>` : ''}
            ${a.status === 'confirmed' ? `<button class="action-btn btn-done" onclick="updateStatus(${a.id}, 'done')">Done</button>` : ''}
            <button class="action-btn btn-delete" onclick="deleteAppt(${a.id})">Delete</button>
          </td>
        </tr>`;
    }).join('');
  }

  function updateStatus(id, status) {
    appointments = appointments.map(a => a.id === id ? {...a, status} : a);
    saveAppts();
    renderDash();
    showToast('Appointment updated!');
  }

  function deleteAppt(id) {
    if (!confirm('Delete this appointment?')) return;
    appointments = appointments.filter(a => a.id !== id);
    saveAppts();
    renderDash();
    showToast('Appointment deleted.');
  }

  function saveAppts() { localStorage.setItem('laishaz_appts', JSON.stringify(appointments)); }

  // ── CONTACT FORM ──
  function sendContactMsg() { showToast('✅ Message sent! We\'ll be in touch soon.'); }

  // ── TOAST ──
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3500);
  }

  // Close modal on overlay click
  document.getElementById('booking-modal').addEventListener('click', function(e) {
    if (e.target === this) closeBooking();
  });

  // Set date field default
  document.addEventListener('DOMContentLoaded', () => {
    const today = new Date().toISOString().split('T')[0];
    if (document.getElementById('appt-date')) {
      document.getElementById('appt-date').min = today;
    }
    refreshNavLoginLink();
    // Allow admins to access the admin login via #admin in the URL
    if (window.location.hash === '#admin') {
      showPage('login', null);
      switchLoginTab('admin');
    }
  });

  // Also respond to hash changes (e.g. typing /#admin while on the site)
  window.addEventListener('hashchange', () => {
    if (window.location.hash === '#admin') {
      showPage('login', null);
      switchLoginTab('admin');
    }
  });
</script>
</body>
</html>
