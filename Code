          <div class="form-group"><label>Phone Number</label><input type="tel" id="book-phone" placeholder="+91 XXXXX XXXXX"/></div>
        </div>
        <div class="form-group"><label>Email (optional)</label><input type="email" id="book-email" placeholder="you@email.com"/></div>
        <div class="form-group"><label>Special Requests</label><textarea id="book-notes" placeholder="Any notes for the stylist..." style="min-height:80px;"></textarea></div>
        <div class="booking-nav">
          <button class="btn-back" onclick="goStep(2)">← Back</button>
          <button class="btn-next" onclick="goStep(4)">Review →</button>
        </div>
