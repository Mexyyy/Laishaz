!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Laishaz Studio – Salon & Spa, Kharghar</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --beige: #f5ede0;
      --beige-dark: #e8d8c4;
      --brown: #7b4f2e;
      --brown-dark: #5a3620;
      --brown-light: #c4956a;
      --white: #fffdf9;
      --text: #3a2a1e;
      --text-light: #8a6a55;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Jost', sans-serif;
      background: var(--white);
      color: var(--text);
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; width: 100%; z-index: 100;
      background: rgba(255,253,249,0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--beige-dark);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 5%;
      height: 70px;
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem; font-weight: 600;
      color: var(--brown-dark); letter-spacing: 0.05em;
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      text-decoration: none; color: var(--text);
      font-size: 0.85rem; letter-spacing: 0.12em; text-transform: uppercase;
      font-weight: 500; transition: color 0.3s;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--brown); }
    .nav-book-btn {
      background: var(--brown); color: white;
      border: none; padding: 0.55rem 1.4rem;
      font-family: 'Jost', sans-serif; font-size: 0.8rem;
      letter-spacing: 0.1em; text-transform: uppercase;
      cursor: pointer; transition: background 0.3s;
      border-radius: 2px;
    }
    .nav-book-btn:hover { background: var(--brown-dark); }

    /* ── PAGES ── */
    .page { display: none; padding-top: 70px; min-height: 100vh; }
    .page.active { display: block; }

    /* ── HOME ── */
    .hero {
      height: calc(100vh - 70px);
      background: linear-gradient(135deg, var(--beige) 0%, var(--beige-dark) 50%, #d4b896 100%);
      display: flex; align-items: center; justify-content: center;
      text-align: center; position: relative; overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%237b4f2e' fill-opacity='0.04'%3E%3Ccircle cx='30' cy='30' r='2'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .hero-content { position: relative; z-index: 1; }
    .hero-tag {
      font-size: 0.75rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--brown-light); margin-bottom: 1.2rem;
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 8vw, 7rem);
      font-weight: 300; line-height: 1.05;
      color: var(--brown-dark); margin-bottom: 1.5rem;
    }
    .hero h1 em { font-style: italic; color: var(--brown); }
    .hero p {
      font-size: 1rem; color: var(--text-light);
      max-width: 440px; margin: 0 auto 2.5rem; line-height: 1.8;
    }
    .hero-btns { display: flex; gap: 1rem; justify-content: center; }
    .btn-primary {
      background: var(--brown); color: white;
      padding: 0.85rem 2.2rem; border: none; cursor: pointer;
      font-family: 'Jost', sans-serif; font-size: 0.85rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      transition: all 0.3s; border-radius: 2px;
    }
    .btn-primary:hover { background: var(--brown-dark); transform: translateY(-2px); }
    .btn-outline {
      background: transparent; color: var(--brown);
      padding: 0.85rem 2.2rem; border: 1.5px solid var(--brown);
      cursor: pointer; font-family: 'Jost', sans-serif; font-size: 0.85rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      transition: all 0.3s; border-radius: 2px;
    }
    .btn-outline:hover { background: var(--brown); color: white; }

    /* Feature strip */
    .features {
      display: grid; grid-template-columns: repeat(3, 1fr);
      background: var(--brown-dark); color: white;
    }
    .feature-item {
      padding: 2.5rem 2rem; text-align: center;
      border-right: 1px solid rgba(255,255,255,0.1);
    }
    .feature-item:last-child { border-right: none; }
    .feature-icon { font-size: 1.8rem; margin-bottom: 0.8rem; }
    .feature-item h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem; font-weight: 400; margin-bottom: 0.4rem;
    }
    .feature-item p { font-size: 0.8rem; opacity: 0.7; line-height: 1.6; }

    /* Popular services on home */
    .section { padding: 6rem 8%; }
    .section-tag {
      font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--brown-light); margin-bottom: 0.8rem;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 3rem); font-weight: 300;
      color: var(--brown-dark); margin-bottom: 1rem; line-height: 1.2;
    }
    .section-sub { color: var(--text-light); font-size: 0.95rem; line-height: 1.8; max-width: 500px; }

    .services-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.5rem; margin-top: 3rem;
    }
    .service-card {
      background: var(--beige); border-radius: 4px;
      padding: 2rem 1.5rem; transition: all 0.3s; cursor: pointer;
      border: 1px solid transparent;
    }
    .service-card:hover {
      border-color: var(--brown-light);
      transform: translateY(-4px);
      box-shadow: 0 12px 30px rgba(123,79,46,0.1);
    }
    .service-card .icon { font-size: 2rem; margin-bottom: 1rem; }
    .service-card h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem; font-weight: 600;
      color: var(--brown-dark); margin-bottom: 0.5rem;
    }
    .service-card p { font-size: 0.83rem; color: var(--text-light); line-height: 1.7; }
    .service-card .price {
      display: inline-block; margin-top: 1rem;
      font-size: 0.85rem; font-weight: 500;
      color: var(--brown); letter-spacing: 0.05em;
    }

    /* Testimonials */
    .testimonials { background: var(--beige); }
    .testi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 3rem; }
    .testi-card {
      background: white; padding: 2rem; border-radius: 4px;
      box-shadow: 0 4px 20px rgba(123,79,46,0.06);
    }
    .stars { color: var(--brown-light); font-size: 0.9rem; margin-bottom: 1rem; }
    .testi-card p { font-size: 0.9rem; line-height: 1.8; color: var(--text); font-style: italic; margin-bottom: 1.2rem; }
    .testi-name { font-weight: 500; font-size: 0.85rem; color: var(--brown); }

    /* ── ABOUT ── */
    .about-hero {
      background: linear-gradient(to right, var(--beige-dark), var(--beige));
      padding: 5rem 8%; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
    }
    .about-hero img { display: none; }
    .about-visual {
      width: 100%; aspect-ratio: 3/4;
      background: linear-gradient(135deg, var(--brown-light), var(--brown));
      border-radius: 4px; display: flex; align-items: center; justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-size: 5rem; color: rgba(255,255,255,0.3);
    }
    .about-text .section-title { font-size: 2.5rem; }
    .about-text p { color: var(--text-light); line-height: 1.9; margin-top: 1.2rem; font-size: 0.95rem; }
    .about-stats { display: flex; gap: 2rem; margin-top: 2rem; }
    .stat { text-align: center; }
    .stat-num {
      font-family: 'Cormorant Garamond', serif; font-size: 2.5rem;
      color: var(--brown); font-weight: 600;
    }
    .stat-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-light); }
    .team-section { padding: 5rem 8%; }
    .team-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 3rem; }
    .team-card { text-align: center; }
    .team-avatar {
      width: 120px; height: 120px; border-radius: 50%;
      background: linear-gradient(135deg, var(--beige-dark), var(--brown-light));
      margin: 0 auto 1rem; display: flex; align-items: center; justify-content: center;
      font-size: 2.5rem;
    }
    .team-card h4 { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: var(--brown-dark); }
    .team-card p { font-size: 0.8rem; color: var(--text-light); margin-top: 0.3rem; }

    /* ── SERVICES PAGE ── */
    .services-hero {
      background: var(--beige); padding: 5rem 8% 3rem; text-align: center;
    }
    .services-hero .section-title { font-size: 3rem; }
    .services-categories { padding: 3rem 8%; }
    .cat-tabs { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 3rem; }
    .cat-tab {
      padding: 0.5rem 1.4rem; border: 1.5px solid var(--beige-dark);
      background: white; color: var(--text-light); cursor: pointer;
      font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase;
      transition: all 0.3s; border-radius: 2px;
    }
    .cat-tab.active, .cat-tab:hover {
      background: var(--brown); color: white; border-color: var(--brown);
    }
    .service-list { display: none; }
    .service-list.active { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; }
    .svc-item {
      padding: 1.8rem; background: var(--beige);
      border-radius: 4px; border-left: 3px solid var(--brown-light);
    }
    .svc-item h4 { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; color: var(--brown-dark); margin-bottom: 0.4rem; }
    .svc-item p { font-size: 0.82rem; color: var(--text-light); line-height: 1.7; }
    .svc-price { font-weight: 500; color: var(--brown); margin-top: 0.8rem; font-size: 0.9rem; }

    /* ── CONTACT ── */
    .contact-wrapper {
      display: grid; grid-template-columns: 1fr 1.2fr; min-height: calc(100vh - 70px);
    }
    .contact-info {
      background: var(--brown-dark); color: white; padding: 5rem 4rem;
      display: flex; flex-direction: column; justify-content: center;
    }
    .contact-info h2 {
      font-family: 'Cormorant Garamond', serif; font-size: 2.5rem;
      font-weight: 300; margin-bottom: 2rem; line-height: 1.2;
    }
    .contact-detail { display: flex; gap: 1rem; margin-bottom: 1.8rem; align-items: flex-start; }
    .c-icon { font-size: 1.2rem; margin-top: 0.1rem; opacity: 0.8; }
    .c-text h4 { font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.6; margin-bottom: 0.3rem; }
    .c-text p { font-size: 0.95rem; line-height: 1.6; }
    .contact-form-area { padding: 5rem 4rem; background: var(--white); }
    .contact-form-area h2 {
      font-family: 'Cormorant Garamond', serif; font-size: 2rem;
      color: var(--brown-dark); margin-bottom: 2rem;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { margin-bottom: 1.2rem; }
    .form-group label {
      display: block; font-size: 0.75rem; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--text-light); margin-bottom: 0.5rem;
    }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 0.75rem 1rem;
      border: 1.5px solid var(--beige-dark); background: var(--beige);
      font-family: 'Jost', sans-serif; font-size: 0.9rem; color: var(--text);
      border-radius: 2px; outline: none; transition: border-color 0.3s;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      border-color: var(--brown-light);
    }
    .form-group textarea { resize: vertical; min-height: 100px; }
    .submit-btn {
      width: 100%; padding: 1rem; background: var(--brown); color: white;
      border: none; font-family: 'Jost', sans-serif; font-size: 0.85rem;
      letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer;
      transition: background 0.3s; border-radius: 2px; margin-top: 0.5rem;
    }
    .submit-btn:hover { background: var(--brown-dark); }

    /* ── BOOKING MODAL ── */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(58,42,30,0.6); backdrop-filter: blur(4px);
      z-index: 1000; align-items: center; justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: white; width: 90%; max-width: 560px;
      border-radius: 6px; overflow: hidden;
      animation: slideUp 0.35s ease;
      max-height: 90vh; overflow-y: auto;
    }
    @keyframes slideUp {
      from { transform: translateY(30px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    .modal-header {
      background: var(--brown-dark); color: white;
      padding: 1.8rem 2rem; display: flex; justify-content: space-between; align-items: center;
    }
    .modal-header h3 {
      font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300;
    }
    .modal-close {
      background: none; border: none; color: white; font-size: 1.5rem;
      cursor: pointer; opacity: 0.7; transition: opacity 0.2s; line-height: 1;
    }
    .modal-close:hover { opacity: 1; }
    .modal-body { padding: 2rem; }
    .booking-steps { display: flex; gap: 0.5rem; margin-bottom: 2rem; }
    .step {
      flex: 1; text-align: center; padding: 0.6rem;
      font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase;
      border-bottom: 2px solid var(--beige-dark); color: var(--text-light);
    }
    .step.active { border-color: var(--brown); color: var(--brown); font-weight: 500; }
    .step.done { border-color: var(--brown-light); color: var(--brown-light); }
    .booking-step-content { display: none; }
    .booking-step-content.active { display: block; }
    .service-options { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1.5rem; }
    .svc-option {
      padding: 1rem; border: 1.5px solid var(--beige-dark);
      border-radius: 4px; cursor: pointer; transition: all 0.25s;
      text-align: center;
    }
    .svc-option:hover, .svc-option.selected {
      border-color: var(--brown); background: var(--beige);
    }
    .svc-option .svc-name { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 600; color: var(--brown-dark); }
    .svc-option .svc-p { font-size: 0.78rem; color: var(--brown-light); margin-top: 0.2rem; }
    .time-slots { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-bottom: 1.5rem; }
    .time-slot {
      padding: 0.6rem; text-align: center; border: 1.5px solid var(--beige-dark);
      border-radius: 4px; cursor: pointer; font-size: 0.82rem; transition: all 0.25s;
    }
    .time-slot:hover, .time-slot.selected { border-color: var(--brown); background: var(--beige); color: var(--brown); }
    .time-slot.unavailable { opacity: 0.4; cursor: not-allowed; text-decoration: line-through; }
    .booking-nav { display: flex; gap: 1rem; margin-top: 1.5rem; }
    .btn-back {
      flex: 1; padding: 0.85rem; border: 1.5px solid var(--beige-dark);
      background: white; cursor: pointer; font-family: 'Jost', sans-serif;
      font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
      transition: all 0.3s; border-radius: 2px; color: var(--text);
    }
    .btn-back:hover { border-color: var(--brown); color: var(--brown); }
    .btn-next {
      flex: 2; padding: 0.85rem; background: var(--brown); color: white;
      border: none; cursor: pointer; font-family: 'Jost', sans-serif;
      font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
      transition: background 0.3s; border-radius: 2px;
    }
    .btn-next:hover { background: var(--brown-dark); }
    .confirmation-box {
      background: var(--beige); border-radius: 4px; padding: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .conf-row { display: flex; justify-content: space-between; padding: 0.5rem 0;
      border-bottom: 1px solid var(--beige-dark); font-size: 0.9rem;
    }
    .conf-row:last-child { border-bottom: none; }
    .conf-row span:first-child { color: var(--text-light); }
    .conf-row span:last-child { font-weight: 500; color: var(--brown-dark); }
    .success-msg { text-align: center; padding: 2rem 1rem; }
    .success-msg .checkmark { font-size: 3rem; margin-bottom: 1rem; }
    .success-msg h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--brown-dark); margin-bottom: 0.5rem; }
    .success-msg p { color: var(--text-light); font-size: 0.9rem; line-height: 1.7; }

    /* ── ADMIN LOGIN ── */
    .admin-login-page {
      min-height: calc(100vh - 70px);
      display: flex; align-items: center; justify-content: center;
      background: linear-gradient(135deg, var(--beige) 0%, var(--beige-dark) 100%);
    }
    .login-card {
      background: white; padding: 3rem; border-radius: 6px;
      width: 380px; box-shadow: 0 20px 60px rgba(123,79,46,0.12);
    }
    .login-card h2 {
      font-family: 'Cormorant Garamond', serif; font-size: 1.8rem;
      color: var(--brown-dark); margin-bottom: 0.3rem;
    }
    .login-card p { font-size: 0.83rem; color: var(--text-light); margin-bottom: 2rem; }
    .login-error { color: #c0392b; font-size: 0.83rem; margin-top: -0.5rem; margin-bottom: 1rem; display: none; }

    /* ── ADMIN DASHBOARD ── */
    .admin-dashboard { display: none; padding: 2rem 4%; }
    .admin-dashboard.visible { display: block; }
    .admin-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 2rem; padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--beige-dark);
    }
    .admin-header h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--brown-dark); }
    .admin-logout {
      padding: 0.5rem 1.2rem; background: transparent; color: var(--brown);
      border: 1.5px solid var(--brown); cursor: pointer; font-family: 'Jost', sans-serif;
      font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;
      transition: all 0.3s; border-radius: 2px;
    }
    .admin-logout:hover { background: var(--brown); color: white; }
    .admin-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem; }
    .admin-stat {
      background: var(--beige); border-radius: 4px; padding: 1.5rem;
      border-left: 3px solid var(--brown-light);
    }
    .admin-stat .num {
      font-family: 'Cormorant Garamond', serif; font-size: 2.2rem;
      color: var(--brown); font-weight: 600;
    }
    .admin-stat .lbl { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-light); margin-top: 0.2rem; }
    .admin-filters { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; align-items: center; }
    .filter-btn {
      padding: 0.45rem 1.1rem; border: 1.5px solid var(--beige-dark);
      background: white; cursor: pointer; font-size: 0.8rem; letter-spacing: 0.08em;
      text-transform: uppercase; transition: all 0.3s; border-radius: 2px; color: var(--text-light);
    }
    .filter-btn.active, .filter-btn:hover { background: var(--brown); color: white; border-color: var(--brown); }
    .appt-table { width: 100%; border-collapse: collapse; background: white; border-radius: 6px; overflow: hidden; box-shadow: 0 4px 20px rgba(123,79,46,0.06); }
    .appt-table th {
      background: var(--brown-dark); color: white; padding: 1rem 1.2rem;
      text-align: left; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 400;
    }
    .appt-table td { padding: 1rem 1.2rem; font-size: 0.88rem; border-bottom: 1px solid var(--beige); }
    .appt-table tr:last-child td { border-bottom: none; }
    .appt-table tr:hover td { background: var(--beige); }
    .badge {
      display: inline-block; padding: 0.2rem 0.7rem; border-radius: 20px;
      font-size: 0.72rem; font-weight: 500; letter-spacing: 0.05em;
    }
    .badge-pending { background: #fef3cd; color: #856404; }
    .badge-confirmed { background: #d1e7dd; color: #0a5232; }
    .badge-done { background: #e2e3e5; color: #383d41; }
    .action-btn {
      padding: 0.3rem 0.8rem; border-radius: 2px; font-size: 0.75rem;
      cursor: pointer; border: none; font-family: 'Jost', sans-serif;
      transition: all 0.2s; margin-right: 0.3rem;
    }
    .btn-confirm { background: var(--brown-light); color: white; }
    .btn-confirm:hover { background: var(--brown); }
    .btn-done { background: #6c757d; color: white; }
    .btn-done:hover { background: #495057; }
    .btn-delete { background: #dc3545; color: white; }
    .btn-delete:hover { background: #c82333; }
    .empty-state { text-align: center; padding: 3rem; color: var(--text-light); }
    .empty-state .ei { font-size: 2.5rem; margin-bottom: 0.8rem; }

    /* ── FOOTER ── */
    footer {
      background: var(--brown-dark); color: white;
      padding: 3rem 8%; display: grid; grid-template-columns: 2fr 1fr 1fr;
      gap: 3rem;
    }
    footer h4 {
